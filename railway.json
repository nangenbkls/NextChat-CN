{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "yarn install && yarn mask && cross-env BUILD_MODE=standalone next build"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "node .next/standalone/server.js",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE"
  }
}
